{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals"]
  },
  "include": [
    "src/types/contracts.js",
    "src/drugs/index.js",
    "src/engine/pkEngine.js",
    "src/ui/controlLogic.js",
    "src/ui/micScale.js",
    "src/ui/drugState.js",
    "src/ui/scenarioState.js",
    "src/ui/uiState.js",
    "src/ui/viewModels.js",
    "src/ui/theme.js",
    "src/ui/chartRuntime.js"
  ]
}
